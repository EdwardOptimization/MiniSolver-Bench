// Generated asset benchmark runner for @CANDIDATE_NAME@.

#ifndef _GNU_SOURCE
#define _GNU_SOURCE
#endif

#include <math.h>
#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>

#include "acados_c/ocp_nlp_interface.h"
#include "acados_solver_@MODEL_NAME@.h"

#ifndef M_PI
#define M_PI 3.14159265358979323846
#endif

#define NX @MODEL_UPPER@_NX
#define NU @MODEL_UPPER@_NU
#define NP @MODEL_UPPER@_NP
#define NH @MODEL_UPPER@_NH
#define N_HORIZON @MODEL_UPPER@_N
#define STEPS_DEFAULT @STEPS_DEFAULT@

typedef struct
{
    int count;
    int cap;
    double *s;
    double *x;
    double *y;
    double *psi;
    double *nx;
    double *ny;
    double *w_left;
    double *w_right;
    double avg_ds;
} driving_track_t;

static int cmp_double(const void *a, const void *b)
{
    const double da = *(const double *) a;
    const double db = *(const double *) b;
    if (da < db) return -1;
    if (da > db) return 1;
    return 0;
}

static double percentile(const double *values, int n, double frac)
{
    if (n <= 0) return 0.0;
    double *tmp = (double *) malloc((size_t) n * sizeof(double));
    for (int i = 0; i < n; ++i) tmp[i] = values[i];
    qsort(tmp, (size_t) n, sizeof(double), cmp_double);
    const double idx = frac * (double) (n - 1);
    const int lo = (int) floor(idx);
    const int hi = (int) ceil(idx);
    const double w = idx - (double) lo;
    const double out = tmp[lo] * (1.0 - w) + tmp[hi] * w;
    free(tmp);
    return out;
}

static double wrap_angle(double angle)
{
    while (angle > M_PI) angle -= 2.0 * M_PI;
    while (angle < -M_PI) angle += 2.0 * M_PI;
    return angle;
}

static void track_reserve(driving_track_t *track, int cap)
{
    if (cap <= track->cap) return;
    track->cap = cap;
    track->s = (double *) realloc(track->s, (size_t) cap * sizeof(double));
    track->x = (double *) realloc(track->x, (size_t) cap * sizeof(double));
    track->y = (double *) realloc(track->y, (size_t) cap * sizeof(double));
    track->psi = (double *) realloc(track->psi, (size_t) cap * sizeof(double));
    track->nx = (double *) realloc(track->nx, (size_t) cap * sizeof(double));
    track->ny = (double *) realloc(track->ny, (size_t) cap * sizeof(double));
    track->w_left = (double *) realloc(track->w_left, (size_t) cap * sizeof(double));
    track->w_right = (double *) realloc(track->w_right, (size_t) cap * sizeof(double));
}

static void track_free(driving_track_t *track)
{
    free(track->s);
    free(track->x);
    free(track->y);
    free(track->psi);
    free(track->nx);
    free(track->ny);
    free(track->w_left);
    free(track->w_right);
    memset(track, 0, sizeof(*track));
}

static int csv_index(char **headers, int n_headers, const char *name)
{
    for (int i = 0; i < n_headers; ++i)
    {
        if (!strcmp(headers[i], name)) return i;
    }
    return -1;
}

static int split_csv(char *line, char **parts, int max_parts)
{
    int count = 0;
    char *saveptr = NULL;
    for (char *tok = strtok_r(line, ",", &saveptr); tok && count < max_parts; tok = strtok_r(NULL, ",", &saveptr))
    {
        while (*tok == ' ' || *tok == '\t') ++tok;
        size_t len = strlen(tok);
        while (len > 0 && (tok[len - 1] == '\n' || tok[len - 1] == '\r' || tok[len - 1] == ' ' || tok[len - 1] == '\t'))
        {
            tok[--len] = '\0';
        }
        parts[count++] = tok;
    }
    return count;
}

static bool load_driving_track(const char *path, driving_track_t *track)
{
    FILE *fp = fopen(path, "r");
    if (!fp) return false;

    char *line = NULL;
    size_t linecap = 0;
    ssize_t linelen = getline(&line, &linecap, fp);
    if (linelen <= 0)
    {
        fclose(fp);
        free(line);
        return false;
    }

    char *headers_buf = strdup(line);
    char *headers[32];
    int n_headers = split_csv(headers_buf, headers, 32);
    int idx_s = csv_index(headers, n_headers, "s");
    int idx_x = csv_index(headers, n_headers, "x_center");
    int idx_y = csv_index(headers, n_headers, "y_center");
    int idx_wl = csv_index(headers, n_headers, "width_left");
    int idx_wr = csv_index(headers, n_headers, "width_right");
    int idx_wi = csv_index(headers, n_headers, "width_inner");
    int idx_wo = csv_index(headers, n_headers, "width_outer");
    free(headers_buf);
    if (idx_s < 0 || idx_x < 0 || idx_y < 0) return false;

    while ((linelen = getline(&line, &linecap, fp)) > 0)
    {
        if (track->count == track->cap) track_reserve(track, track->cap > 0 ? 2 * track->cap : 256);
        char *parts_buf = strdup(line);
        char *parts[32];
        int n_parts = split_csv(parts_buf, parts, 32);
        if (n_parts > idx_y)
        {
            track->s[track->count] = atof(parts[idx_s]);
            track->x[track->count] = atof(parts[idx_x]);
            track->y[track->count] = atof(parts[idx_y]);
            if (idx_wl >= 0 && idx_wr >= 0)
            {
                track->w_left[track->count] = atof(parts[idx_wl]);
                track->w_right[track->count] = atof(parts[idx_wr]);
            }
            else
            {
                const double w_in = atof(parts[idx_wi]);
                const double w_out = atof(parts[idx_wo]);
                const double width = w_in < w_out ? w_in : w_out;
                track->w_left[track->count] = width;
                track->w_right[track->count] = width;
            }
            track->count++;
        }
        free(parts_buf);
    }
    fclose(fp);
    free(line);

    if (track->count > 1)
    {
        track->avg_ds = track->s[track->count - 1] / (double) (track->count - 1);
    }
    else
    {
        track->avg_ds = 0.1;
    }

    for (int i = 0; i < track->count; ++i)
    {
        const int prev = (i == 0) ? (track->count - 1) : (i - 1);
        const int next = (i + 1) % track->count;
        const double dx = track->x[next] - track->x[prev];
        const double dy = track->y[next] - track->y[prev];
        const double psi = atan2(dy, dx);
        track->psi[i] = psi;
        track->nx[i] = -sin(psi);
        track->ny[i] = cos(psi);
    }
    return true;
}

static int nearest_cyclic_index(const driving_track_t *track, double x, double y, int anchor, int window)
{
    const int n = track->count;
    int best = anchor % n;
    double best_dist = 1e300;
    for (int offset = 0; offset <= window; ++offset)
    {
        int candidates[2] = {
            (anchor + offset) % n,
            (anchor + n - (offset % n)) % n
        };
        for (int j = 0; j < 2; ++j)
        {
            const int idx = candidates[j];
            const double dx = x - track->x[idx];
            const double dy = y - track->y[idx];
            const double dist = dx * dx + dy * dy;
            if (dist < best_dist)
            {
                best_dist = dist;
                best = idx;
            }
        }
    }
    return best;
}

static void stage_params(const driving_track_t *track, int idx, double target_speed, double *p)
{
    p[0] = track->x[idx];
    p[1] = track->y[idx];
    p[2] = track->psi[idx];
    p[3] = target_speed;
    p[4] = track->nx[idx];
    p[5] = track->ny[idx];
    p[6] = track->w_left[idx];
    p[7] = track->w_right[idx];
}

int main(int argc, char **argv)
{
    const char *asset_path = NULL;
    const char *output_path = "results/raw/acados/@CANDIDATE_NAME@.csv";
    int steps = STEPS_DEFAULT;
    double target_speed = @TARGET_SPEED@;
    for (int i = 1; i < argc; ++i)
    {
        if (!strcmp(argv[i], "--asset") && i + 1 < argc) { asset_path = argv[++i]; continue; }
        if (!strcmp(argv[i], "--output") && i + 1 < argc) { output_path = argv[++i]; continue; }
        if (!strcmp(argv[i], "--steps") && i + 1 < argc) { steps = atoi(argv[++i]); continue; }
        if (!strcmp(argv[i], "--target-speed") && i + 1 < argc) { target_speed = atof(argv[++i]); continue; }
        fprintf(stderr, "Unknown argument: %s\n", argv[i]);
        return 1;
    }
    if (!asset_path)
    {
        fprintf(stderr, "--asset is required\n");
        return 1;
    }

    driving_track_t track = {0};
    if (!load_driving_track(asset_path, &track))
    {
        fprintf(stderr, "failed to load track asset: %s\n", asset_path);
        return 1;
    }

    @MODEL_NAME@_solver_capsule *solver_capsule = @MODEL_NAME@_acados_create_capsule();
    if (@MODEL_NAME@_acados_create(solver_capsule) != 0)
    {
        fprintf(stderr, "@MODEL_NAME@_acados_create failed\n");
        track_free(&track);
        return 1;
    }

    ocp_nlp_config *nlp_config = @MODEL_NAME@_acados_get_nlp_config(solver_capsule);
    ocp_nlp_dims *nlp_dims = @MODEL_NAME@_acados_get_nlp_dims(solver_capsule);
    ocp_nlp_in *nlp_in = @MODEL_NAME@_acados_get_nlp_in(solver_capsule);
    ocp_nlp_out *nlp_out = @MODEL_NAME@_acados_get_nlp_out(solver_capsule);
    ocp_nlp_solver *nlp_solver = @MODEL_NAME@_acados_get_nlp_solver(solver_capsule);

    const double dt = @DT@;
    const double wheelbase = 0.33;
    const double v_min = 0.1;
    const double v_max = 12.0;
    const double delta_min = -0.50;
    const double delta_max = 0.50;
    const int stride = (int) fmax(1.0, llround(target_speed * dt / fmax(track.avg_ds, 1e-6)));

    double xcurrent[NX] = {track.x[0], track.y[0], track.psi[0], target_speed, 0.0};
    double x_guess[NX] = {track.x[0], track.y[0], track.psi[0], target_speed, 0.0};
    double u_guess[NU] = {0.0, 0.0};
    for (int k = 0; k < N_HORIZON; ++k)
    {
        ocp_nlp_out_set(nlp_config, nlp_dims, nlp_out, nlp_in, k, "x", x_guess);
        ocp_nlp_out_set(nlp_config, nlp_dims, nlp_out, nlp_in, k, "u", u_guess);
    }
    ocp_nlp_out_set(nlp_config, nlp_dims, nlp_out, nlp_in, N_HORIZON, "x", x_guess);

    FILE *csv = fopen(output_path, "w");
    if (!csv)
    {
        perror("fopen");
        @MODEL_NAME@_acados_free(solver_capsule);
        @MODEL_NAME@_acados_free_capsule(solver_capsule);
        track_free(&track);
        return 1;
    }
    fprintf(csv, "step,status,time_ms,iterations,x,y,psi,v,delta,tracking_error,max_constraint_violation,ref_index\n");

    double *times = (double *) calloc((size_t) steps, sizeof(double));
    int success = 0;
    int ref_idx = 0;
    for (int step = 0; step < steps; ++step)
    {
        double p_stage[NP];
        for (int k = 0; k <= N_HORIZON; ++k)
        {
            const int idx = (ref_idx + k * stride) % track.count;
            stage_params(&track, idx, target_speed, p_stage);
            @MODEL_NAME@_acados_update_params(solver_capsule, k, p_stage, NP);
        }

        ocp_nlp_constraints_model_set(nlp_config, nlp_dims, nlp_in, nlp_out, 0, "lbx", xcurrent);
        ocp_nlp_constraints_model_set(nlp_config, nlp_dims, nlp_in, nlp_out, 0, "ubx", xcurrent);

        int status = @MODEL_NAME@_acados_solve(solver_capsule);
        double elapsed = 0.0;
        int sqp_iter = 0;
        ocp_nlp_get(nlp_solver, "time_tot", &elapsed);
        ocp_nlp_get(nlp_solver, "sqp_iter", &sqp_iter);

        double u0[NU];
        ocp_nlp_out_get(nlp_config, nlp_dims, nlp_out, 0, "u", u0);

        stage_params(&track, ref_idx, target_speed, p_stage);
        const double lateral = p_stage[4] * (xcurrent[0] - p_stage[0]) + p_stage[5] * (xcurrent[1] - p_stage[1]);
        double max_viol = 0.0;
        const double cands[6] = {
            lateral - p_stage[6],
            -lateral - p_stage[7],
            xcurrent[3] - v_max,
            v_min - xcurrent[3],
            xcurrent[4] - delta_max,
            delta_min - xcurrent[4],
        };
        for (int i = 0; i < 6; ++i) if (cands[i] > max_viol) max_viol = cands[i];
        const double tracking_error = hypot(xcurrent[0] - p_stage[0], xcurrent[1] - p_stage[1]);

        fprintf(csv, "%d,%d,%.9f,%d,%.9f,%.9f,%.9f,%.9f,%.9f,%.9f,%.9f,%d\n",
                step, status, elapsed * 1000.0, sqp_iter, xcurrent[0], xcurrent[1], xcurrent[2], xcurrent[3], xcurrent[4],
                tracking_error, max_viol, ref_idx);

        if (status == 0) success++;
        times[step] = elapsed * 1000.0;

        xcurrent[0] += xcurrent[3] * cos(xcurrent[2]) * dt;
        xcurrent[1] += xcurrent[3] * sin(xcurrent[2]) * dt;
        xcurrent[2] = wrap_angle(xcurrent[2] + xcurrent[3] * tan(xcurrent[4]) / wheelbase * dt);
        xcurrent[3] += u0[0] * dt;
        if (xcurrent[3] < v_min) xcurrent[3] = v_min;
        if (xcurrent[3] > v_max) xcurrent[3] = v_max;
        xcurrent[4] += u0[1] * dt;
        if (xcurrent[4] < delta_min) xcurrent[4] = delta_min;
        if (xcurrent[4] > delta_max) xcurrent[4] = delta_max;
        ref_idx = nearest_cyclic_index(&track, xcurrent[0], xcurrent[1], ref_idx + stride, 30 + 4 * stride);
    }
    fclose(csv);

    double max_ms = 0.0;
    for (int i = 0; i < steps; ++i) if (times[i] > max_ms) max_ms = times[i];
    printf("candidate=%s steps=%d success=%d median_ms=%.6f p95_ms=%.6f max_ms=%.6f output=%s\n",
           "@CANDIDATE_NAME@", steps, success, percentile(times, steps, 0.5), percentile(times, steps, 0.95), max_ms, output_path);

    free(times);
    @MODEL_NAME@_acados_free(solver_capsule);
    @MODEL_NAME@_acados_free_capsule(solver_capsule);
    track_free(&track);
    return 0;
}
